{
  "name": "chatdaddy-ai-agent-starter",
  "version": "0.1.0",
  "private": false,
  "description": "A public-safe starter for a ChatDaddy WhatsApp AI reply agent with dashboard, approval loop, and Google Sheet logging.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "secret:openai": "wrangler secret put OPENAI_API_KEY",
    "secret:chatdaddy": "wrangler secret put CHATDADDY_API_KEY",
    "secret:admin": "wrangler secret put ADMIN_TOKEN",
    "secret:webhook": "wrangler secret put CHATDADDY_WEBHOOK_SECRET",
    "secret:sheet": "wrangler secret put GOOGLE_SHEET_SECRET",
    "dev:agents": "wrangler dev --config wrangler.agents.example.toml",
    "deploy:agents": "wrangler deploy --config wrangler.agents.example.toml",
    "check:agents": "node --check src/hermas-agents-worker.js",
    "check:live-launch": "node scripts/check_agents_live_launch_preflight.mjs",
    "seed:beyoute": "node scripts/apply_supabase_beyoute_seed_via_rest.mjs",
    "prepare:agents-config": "node scripts/prepare_agents_live_config.mjs",
    "deploy:agents:local": "wrangler deploy --config wrangler.agents.local.toml"
  },
  "dependencies": {
    "agents": "^0.17.3"
  },
  "devDependencies": {
    "wrangler": "^4.106.0"
  }
}
