# Copy this file to .dev.vars for local Wrangler development.
# Do not commit real values.

PROJECT_KEY=demo
PROJECT_NAME="Demo WhatsApp AI Reply Agent"
AUTO_SEND=false
AI_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini

# Secrets: set with `wrangler secret put ...`
OPENAI_API_KEY=
CHATDADDY_API_KEY=
CHATDADDY_WEBHOOK_SECRET=
ADMIN_TOKEN=
GOOGLE_SHEET_SECRET=

# ChatDaddy connector values.
CHATDADDY_ACCOUNT_ID=
CHATDADDY_REPLY_BOT_ID=
CHATDADDY_BOTS_FIRE_BASE=https://api-bots.chatdaddy.tech

# Optional Google Sheet Apps Script Web App URL.
GOOGLE_SHEET_WEB_APP_URL=
